<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ClienteController">
    <children>

        <!-- Encabezado -->
        <VBox alignment="CENTER_LEFT" prefHeight="90.0" style="-fx-background-color: #fcf9f2; -fx-border-color: #d4af37; -fx-border-width: 0 0 3px 0; -fx-padding: 20 30 20 30;">
            <children>
                <Label text="Gestión de Clientes" textFill="#1a1a1a">
                    <font>
                        <Font name="Georgia Bold" size="24.0" />
                    </font>
                </Label>
                <Label text="Registra y administra tus clientes" textFill="#8c7653">
                    <font>
                        <Font name="Georgia Italic" size="13.0" />
                    </font>
                </Label>
                <Button fx:id="btnVolver" onAction="#irADashboard" text="&#8592; Volver al Dashboard"
                        style="-fx-background-color: transparent; -fx-text-fill: #8c7653; -fx-cursor: hand; -fx-padding: 0;">
                    <VBox.margin>
                        <Insets top="8.0" />
                    </VBox.margin>
                </Button>
                <Button fx:id="btnCerrarSesion" onAction="#handleCerrarSesion" text="Cerrar Sesión"
                        style="-fx-background-color: #3a1e1e; -fx-text-fill: #ff8888; -fx-cursor: hand; -fx-background-radius: 5;">
                    <VBox.margin>
                        <Insets top="4.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>

        <!-- Formulario -->
        <VBox spacing="10.0" style="-fx-padding: 25 30 15 30;">
            <children>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Nombre" textFill="#555555">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <TextField fx:id="txtNombre" promptText="Ej. María Torres" prefWidth="200.0"
                                           style="-fx-padding: 9; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;" />
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Teléfono" textFill="#555555">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <TextField fx:id="txtTelefono" promptText="0999999999" prefWidth="150.0"
                                           style="-fx-padding: 9; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;" />
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Correo" textFill="#555555">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <TextField fx:id="txtCorreo" promptText="correo@mail.com" prefWidth="200.0"
                                           style="-fx-padding: 9; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;" />
                            </children>
                        </VBox>
                        <Button fx:id="btnGuardar" onAction="#handleGuardarCliente" text="Guardar" prefHeight="38.0"
                                style="-fx-background-color: linear-gradient(to right, #bfa36f, #d4af37); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;">
                            <VBox.margin><Insets top="17.0" /></VBox.margin>
                        </Button>
                        <Button fx:id="btnEliminar" onAction="#handleEliminarCliente" text="Eliminar" prefHeight="38.0"
                                style="-fx-background-color: #b8503f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;">
                            <VBox.margin><Insets top="17.0" /></VBox.margin>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- Tabla -->
        <VBox style="-fx-padding: 0 30 25 30;" VBox.vgrow="ALWAYS">
            <children>
                <TableView fx:id="tablaClientes" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-border-color: #e0d5b8; -fx-border-radius: 6;">
                    <columns>
                        <TableColumn fx:id="colNombre" text="Nombre" prefWidth="250.0" />
                        <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="180.0" />
                        <TableColumn fx:id="colCorreo" text="Correo" prefWidth="280.0" />
                    </columns>
                </TableView>
            </children>
        </VBox>

    </children>
</VBox>