<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="800.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ClienteController">
    <children>

        <VBox alignment="CENTER_LEFT" prefHeight="90.0" style="-fx-background-color: #fcf9f2; -fx-border-color: #d4af37; -fx-border-width: 0 0 3px 0; -fx-padding: 20 30 20 30;">
            <children>
                <Label text="Gestión de Clientes" textFill="#1a1a1a">
                    <font><Font name="Georgia Bold" size="24.0" /></font>
                </Label>
            </children>
        </VBox>

        <VBox spacing="10.0" style="-fx-padding: 25 30 15 30;">
            <children>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <children>
                        <TextField fx:id="txtNombre" promptText="Nombre" prefWidth="200.0"
                                   style="-fx-padding: 9; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;" />
                        <TextField fx:id="txtTelefono" promptText="Teléfono" prefWidth="150.0"
                                   style="-fx-padding: 9; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;" />
                        <TextField fx:id="txtCorreo" promptText="Correo" prefWidth="200.0"
                                   style="-fx-padding: 9; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;" />
                        <Button fx:id="btnGuardar" onAction="#handleGuardarCliente" text="Guardar"
                                style="-fx-background-color: linear-gradient(to right, #bfa36f, #d4af37); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;" />
                        <Button fx:id="btnEliminar" onAction="#handleEliminarCliente" text="Eliminar"
                                style="-fx-background-color: #b8503f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox style="-fx-padding: 0 30 25 30;" VBox.vgrow="ALWAYS">
            <children>
                <TableView fx:id="tablaClientes" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNombre" text="Nombre" prefWidth="250.0" />
                        <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="180.0" />
                        <TableColumn fx:id="colCorreo" text="Correo" prefWidth="280.0" />
                    </columns>
                </TableView>
            </children>
        </VBox>

    </children>
</VBox>