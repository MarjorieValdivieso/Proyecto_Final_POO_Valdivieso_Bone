<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefWidth="900.0" style="-fx-background-color:#ffffff;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ReporteController">

    <children>

        <!-- ENCABEZADO -->
        <VBox alignment="CENTER_LEFT" prefHeight="90" style="-fx-background-color:#fcf9f2;                      -fx-border-color:#d4af37;                      -fx-border-width:0 0 3 0;                      -fx-padding:20 30 20 30;">

            <children>

                <Label text="Reportes del Sistema" textFill="#1a1a1a">
                    <font>
                        <Font name="Georgia Bold" size="24" />
                    </font>
                </Label>

            </children>

        </VBox>

        <!-- CITAS -->

        <VBox spacing="10" style="-fx-padding:20 30 10 30;">

            <children>

                <Label style="-fx-font-size:18;                               -fx-font-weight:bold;                               -fx-text-fill:#b8860b;" text="Citas" />

                <TableView fx:id="tablaCitas" prefHeight="286.0" prefWidth="839.0">

                    <columns>

                        <TableColumn fx:id="colClienteCita" prefWidth="350" text="Cliente" />

                        <TableColumn fx:id="colEstado" prefWidth="220" text="Estado" />

                    </columns>

                </TableView>

            </children>

        </VBox>

        <!-- SERVICIOS -->

        <VBox spacing="10" style="-fx-padding:5 30 10 30;">

            <children>

                <Label style="-fx-font-size:18;                               -fx-font-weight:bold;                               -fx-text-fill:#b8860b;" text="Servicios" />

                <TableView fx:id="tablaServicios" prefHeight="280.0" prefWidth="839.0">

                    <columns>

                        <TableColumn fx:id="colNombreServicio" prefWidth="350" text="Servicio" />

                        <TableColumn fx:id="colPrecio" prefWidth="220" text="Precio" />

                    </columns>

                </TableView>

            </children>

        </VBox>

        <!-- CLIENTES -->

        <VBox prefHeight="419.0" prefWidth="900.0" spacing="10" style="-fx-padding:5 30 25 30;" VBox.vgrow="ALWAYS">

            <children>

                <Label style="-fx-font-size:18;                               -fx-font-weight:bold;                               -fx-text-fill:#b8860b;" text="Clientes" />

                <TableView fx:id="tablaClientes" prefHeight="267.0" prefWidth="839.0" VBox.vgrow="ALWAYS">

                    <columns>

                        <TableColumn fx:id="colNombreCliente" prefWidth="350" text="Nombre" />

                        <TableColumn fx:id="colTelefono" prefWidth="220" text="Teléfono" />

                    </columns>

                </TableView>

            </children>

        </VBox>

    </children>

</VBox>
