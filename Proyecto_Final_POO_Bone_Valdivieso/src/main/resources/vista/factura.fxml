<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="rootFactura" prefWidth="480.0" style="-fx-background-color: #ffffff; -fx-padding: 30;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.FacturaController">
    <children>

        <VBox alignment="CENTER" spacing="4.0" style="-fx-padding: 0 0 20 0;">
            <children>
                <Label text="BELLEZA ELEGANTE" textFill="#1a1a1a">
                    <font><Font name="Georgia Bold" size="22.0" /></font>
                </Label>
                <Label text="Comprobante de Pago" textFill="#d4af37">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>
            </children>
        </VBox>

        <Separator />

        <VBox spacing="6.0" style="-fx-padding: 20 0 20 0;">
            <children>
                <HBox spacing="10.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="N° Comprobante:" />
                        <Label fx:id="lblNumero" text="0000" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Fecha de emisión:" />
                        <Label fx:id="lblFechaEmision" text="-" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Cliente:" />
                        <Label fx:id="lblCliente" text="-" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <Separator />

        <VBox spacing="10.0" style="-fx-padding: 20 0 20 0;">
            <children>
                <HBox spacing="10.0">
                    <children>
                        <Label prefWidth="100.0" style="-fx-font-weight: bold;" text="Servicio:" />
                        <Label fx:id="lblServicio" text="-" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label prefWidth="100.0" style="-fx-font-weight: bold;" text="Fecha cita:" />
                        <Label fx:id="lblFechaCita" text="-" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label prefWidth="100.0" style="-fx-font-weight: bold;" text="Hora:" />
                        <Label fx:id="lblHora" text="-" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label prefWidth="100.0" style="-fx-font-weight: bold;" text="Estado:" />
                        <Label fx:id="lblEstado" text="-" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <Separator />

        <VBox spacing="8.0" style="-fx-padding: 20 0 20 0;">
            <children>
                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Label text="Subtotal:" />
                        <Label fx:id="lblSubtotal" text="\$0.00" />
                    </children>
                </HBox>
                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Label text="IVA (15%):" />
                        <Label fx:id="lblIva" text="\$0.00" />
                    </children>
                </HBox>
                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="TOTAL:" />
                        <Label fx:id="lblTotal" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #d4af37;" text="\$0.00" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <Label style="-fx-padding: 15 0 15 0;" text="Gracias por su preferencia" textFill="#555555" wrapText="true" />

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button fx:id="btnImprimir" onAction="#handleImprimir" prefHeight="38.0" style="-fx-background-color: linear-gradient(to right, #bfa36f, #d4af37); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Imprimir" />
                <Button fx:id="btnCerrar" onAction="#handleCerrar" prefHeight="38.0" style="-fx-background-color: #cccccc; -fx-text-fill: #1a1a1a; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Cerrar" />
            </children>
        </HBox>

    </children>
</VBox>
